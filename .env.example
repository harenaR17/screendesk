# Server
PORT=3000
NODE_ENV=development

# Storage paths (relative to repo root)
RECORDINGS_DIR=recordings
TMP_DIR=tmp
DB_PATH=db/screendeck.db

# FFmpeg binary path (leave empty to use system PATH) — used in Phase 3
FFMPEG_PATH=

# Max upload size in bytes (default 2GB) — used in Phase 3
MAX_UPLOAD_SIZE=2147483648
